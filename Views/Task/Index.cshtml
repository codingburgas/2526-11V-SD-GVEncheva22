@model IEnumerable<project_GVEncheva22.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="text-primary">Tasks</h1>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-success btn-lg">
                        <i class="fas fa-plus"></i> Create New Task
                    </a>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info" role="alert">
                    <h4 class="alert-heading">No Tasks Found</h4>
                    <p>No tasks have been created yet.</p>
                    @if (User.IsInRole("Admin"))
                    {
                        <hr>
                        <p class="mb-0">
                            <a asp-action="Create" class="btn btn-primary">Create Your First Task</a>
                        </p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Title)</th>
                                <th>@Html.DisplayNameFor(model => model.Priority)</th>
                                <th>@Html.DisplayNameFor(model => model.Status)</th>
                                <th>@Html.DisplayNameFor(model => model.Board.Title)</th>
                                <th>@Html.DisplayNameFor(model => model.Deadline)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@Html.DisplayFor(modelItem => item.Title)</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(item.Priority == project_GVEncheva22.Models.Priority.High ? "danger" : item.Priority == project_GVEncheva22.Models.Priority.Medium ? "warning" : "secondary")">
                                            @item.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(item.Status == project_GVEncheva22.Models.Status.Done ? "success" : item.Status == project_GVEncheva22.Models.Status.InProgress ? "primary" : "light")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>@Html.DisplayFor(modelItem => item.Board.Title)</td>
                                    <td>
                                        @if (item.Deadline.HasValue)
                                        {
                                            <span class="@(item.Deadline < DateTime.Now ? "text-danger" : "text-muted")">
                                                @item.Deadline.Value.ToString("MMM dd, yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No deadline</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm me-1">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                                <i class="fas fa-trash"></i> Delete
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>