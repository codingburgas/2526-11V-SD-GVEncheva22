@model project_GVEncheva22.Models.Board

@{
    ViewData["Title"] = "Delete Board";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Boards</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">@Model.Title</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Delete</li>
                </ol>
            </nav>

            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="card-title h4 mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Delete Board
                    </h1>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger" role="alert">
                        <h4 class="alert-heading">⚠️ Warning!</h4>
                        <p>Are you sure you want to delete this board? This action cannot be undone.</p>
                        <hr>
                        <p class="mb-0">All associated tasks will also be deleted.</p>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Title</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Title)</dd>
                        <dt class="col-sm-4 fw-bold">Created</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</dd>
                        <dt class="col-sm-4 fw-bold">Tasks Count</dt>
                        <dd class="col-sm-8">@(Model.TaskItems?.Count ?? 0) tasks</dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <form asp-action="Delete" class="d-inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger me-2">
                            <i class="fas fa-trash"></i> Yes, Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>