@{
    ViewData["Title"] = "Dashboard"; // Page title in browser tab
}


<!-- Main container with margin -->
<div class="container mt-4">

    <!-- Page heading -->
    <h1 class="mb-4">Task Management Dashboard</h1>


    <!-- Top statistics row -->
    <div class="row">

        <!-- Completed tasks card -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">

                    <!-- Icon -->
                    <div class="display-4 text-success mb-2">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>

                    <!-- Completed tasks count -->
                    <h3 class="card-title text-success">@ViewBag.CompletedTasks</h3>

                    <!-- Label -->
                    <p class="card-text text-muted">Completed Tasks</p>
                </div>
            </div>
        </div>

        <!-- Pending tasks card -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-primary mb-2">

                        <!-- Icon -->
                        <i class="bi bi-clock-fill"></i>
                    </div>

                    <!-- Pending tasks count -->
                    <h3 class="card-title text-primary">@ViewBag.PendingTasks</h3>
                    <p class="card-text text-muted">Pending Tasks</p>
                </div>
            </div>
        </div>

        <!-- Overdue tasks card -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-danger mb-2">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>

                    <!-- Overdue tasks count -->
                    <h3 class="card-title text-danger">@ViewBag.OverdueTasks</h3>
                    <p class="card-text text-muted">Overdue Tasks</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Second row (deadlines + actions) -->
    <div class="row">

        <!-- Upcoming deadlines section -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Upcoming Deadlines
                </div>
                <div class="card-body">

                    <!-- Check if there are upcoming deadlines -->
                    @if (ViewBag.UpcomingDeadlines.Count > 0)
                    {
                        <ul class="list-group list-group-flush">

                            <!-- Loop through tasks with deadlines -->
                            @foreach (var task in ViewBag.UpcomingDeadlines)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">

                                    <!-- Task title -->
                                    @task.Title

                                    <!-- Deadline badge -->
                                    <span class="badge badge-primary badge-pill">@task.Deadline?.ToString("MMM dd")</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <!-- Message when no deadlines exist -->
                        <p class="text-muted">No upcoming deadlines.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Quick actions section -->
        <div class="col-md-6">
            <div class="card">

                <!-- Section header -->
                <div class="card-header">
                    Quick Actions
                </div>
                <div class="card-body">

                    <!-- Navigation buttons -->
                    <a href="/Board" class="btn btn-primary btn-block mb-2">Manage Boards</a>
                    <a href="/Task" class="btn btn-secondary btn-block mb-2">Manage Tasks</a>
                    <a href="/Task/GroupedByStatus" class="btn btn-info btn-block">View Tasks by Status</a>
                </div>
            </div>
        </div>
    </div>
</div>